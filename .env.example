# Ooty Nigel Travels — environment configuration
# Copy to .env.local and fill in for production.

# Signs and verifies session cookies (admin + customer auth). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-64-char-hex-string

# Public site origin, used for canonical URLs / metadata / sitemap.
NEXT_PUBLIC_SITE_URL=http://localhost:3000


OPENROUTER_API_KEY="change-me"
OPENROUTER_MODEL="openai/gpt-4o-mini"

# Used only by scripts/fetch-package-images.mjs (one-off build-time image download), never sent to the client.
# Get a free Access Key at https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY="change-me"

