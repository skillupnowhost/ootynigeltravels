# Ooty Nigel Travels — environment configuration
# Copy to .env.local and fill in for production.

# Postgres connection string. When a Vercel Postgres store is linked to this
# project, Vercel injects POSTGRES_URL automatically — nothing to set here for
# deployed environments. For local dev, either `vercel env pull` to get the
# same value, or set DATABASE_URL to a Neon (or other Postgres) connection
# string directly.
POSTGRES_URL=
DATABASE_URL=

# Signs and verifies session cookies (admin + customer auth). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-64-char-hex-string

# Public site origin, used for canonical URLs / metadata / sitemap.
NEXT_PUBLIC_SITE_URL=http://localhost:3000


OPENROUTER_API_KEY="change-me"
OPENROUTER_MODEL="openai/gpt-4o-mini"

# Used only by scripts/fetch-package-images.mjs (one-off build-time image download), never sent to the client.
# Get a free Access Key at https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY="change-me"

# Twilio — sends real OTP codes, booking confirmations and quotation SMS/WhatsApp
# messages. Without these set, src/lib/sms.ts falls back to logging the message
# to the server console instead (dev-safe, no account needed).
# Find ACCOUNT_SID / AUTH_TOKEN on the Twilio Console dashboard.
TWILIO_ACCOUNT_SID="change-me"
TWILIO_AUTH_TOKEN="change-me"
# A Twilio phone number capable of sending SMS, e.g. "+15017122661".
TWILIO_SMS_FROM="change-me"
# A WhatsApp-enabled sender, e.g. "whatsapp:+14155238886" for the free Sandbox
# (testers must first send the sandbox join code from their WhatsApp), or your
# own approved WhatsApp Business number once live. Leave blank to send SMS only.
TWILIO_WHATSAPP_FROM=""

# Powers the live Google reviews feed on /reviews. Enable the "Places API (New)"
# in Google Cloud Console and create an API key restricted to that API.
GOOGLE_PLACES_API_KEY="change-me"
# The Place ID for our Google Business listing — find it at
# https://developers.google.com/maps/documentation/places/web-service/place-id-finder
GOOGLE_PLACE_ID="change-me"

